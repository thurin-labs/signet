{
  "name": "@thurinlabs/signet-sdk",
  "version": "0.1.0",
  "description": "SDK for verifying ETH↔PGP attestations on the Signet PGPRegistry",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "dependencies": {
    "openpgp": "^6.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "viem": "^2.21.0",
    "vitest": "^1.0.0"
  }
}
